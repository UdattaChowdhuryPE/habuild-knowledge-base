# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Voyage AI Embeddings
VOYAGE_API_KEY=your_voyage_api_key_here

# Supabase Database
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Email domain allowlist (comma-separated)
# Controls which email domains are allowed to access the app
ALLOWED_EMAIL_DOMAINS=@company.com,.company@gmail.com

# Frontend (Next.js) - public Supabase variables
# These are prefixed with NEXT_PUBLIC_ and are exposed to the browser
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
