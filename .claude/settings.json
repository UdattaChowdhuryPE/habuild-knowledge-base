{
  "enabledPlugins": {
    "claude-api@claude-plugins-official": true,
    "simplify@claude-plugins-official": true,
    "security-review@claude-plugins-official": true,
    "fewer-permission-prompts@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "Bash(mkdir *)",
